rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null && request.auth.token.email is string;
    }

    match /shares/{shareId} {
      allow create: if signedIn()
        && request.resource.data.senderUid == request.auth.uid
        && request.resource.data.senderEmail == request.auth.token.email
        && request.resource.data.recipientEmail is string
        && request.resource.data.title is string
        && request.resource.data.content is string
        && request.resource.data.sourceDocumentId is string
        && request.resource.data.status == 'pending';

      allow read: if signedIn()
        && (
          resource.data.senderUid == request.auth.uid
          || resource.data.recipientEmail == request.auth.token.email
        );

      allow update: if signedIn()
        && resource.data.recipientEmail == request.auth.token.email
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'acceptedAt'])
        && request.resource.data.status in ['accepted', 'declined'];

      allow delete: if false;
    }
  }
}
